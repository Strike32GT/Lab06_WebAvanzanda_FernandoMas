<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Social Media - <%= postToEdit ? "Editar post" : "Nuevo post" %></title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <style>
    :root {
      --page-bg: #f3f8d8;
      --nav-bg: #0d215f;
      --nav-accent: #6cd4c3;
      --card-border: #b8e7dc;
      --card-bg: #fcfcfc;
      --text-main: #10214f;
      --button-main: #0b1f66;
    }

    body {
      background: var(--page-bg);
      color: var(--text-main);
      font-family: Georgia, "Times New Roman", serif;
    }

    .topbar {
      background: var(--nav-bg);
      padding: 0 26px;
      box-shadow: none;
    }

    .topbar .brand-logo {
      color: var(--nav-accent);
      font-size: 2rem;
      font-weight: 500;
      position: static;
      transform: none;
    }

    .topbar .nav-wrapper {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 72px;
    }

    .topbar nav ul a,
    .topbar .nav-link {
      color: #d4fff8;
      font-size: 1.15rem;
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-new {
      border-radius: 12px;
      background: #123ca2;
      color: white;
      padding: 0 18px;
      font-weight: 700;
      box-shadow: none;
      text-transform: none;
    }

    .page-content {
      padding: 36px 18px 48px;
    }

    .composer-card {
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid var(--card-border);
      border-radius: 24px;
      padding: 16px;
      box-shadow: none;
    }

    .composer-card .card-title {
      color: var(--text-main);
      font-size: 3rem;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .helper-copy {
      color: #4f658b;
      font-size: 1.05rem;
      margin-bottom: 24px;
    }

    .input-field input,
    .input-field textarea {
      color: var(--text-main);
    }

    .input-field input:focus + label,
    .input-field textarea:focus + label {
      color: #2d7d73 !important;
    }

    .input-field input:focus,
    .input-field textarea:focus {
      border-bottom: 1px solid #2d7d73 !important;
      box-shadow: 0 1px 0 0 #2d7d73 !important;
    }

    .form-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 10px;
    }

    .primary-action {
      background: var(--button-main);
      border-radius: 14px;
      text-transform: none;
      box-shadow: none;
      font-weight: 700;
    }

    .secondary-action {
      color: var(--text-main);
      font-weight: 700;
      font-size: 1.05rem;
    }

    .status-panel {
      border-radius: 18px;
      border: 1px solid var(--card-border);
      box-shadow: none;
      margin-bottom: 22px;
    }

    @media only screen and (max-width: 992px) {
      .topbar .nav-wrapper {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
        padding: 16px 0;
      }

      .nav-actions {
        width: 100%;
        justify-content: space-between;
        flex-wrap: wrap;
      }

      .topbar ul {
        display: flex;
        gap: 14px;
      }

      .composer-card .card-title {
        font-size: 2.2rem;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <nav class="transparent z-depth-0">
      <div class="nav-wrapper">
        <a href="/" class="brand-logo">Social Media</a>

        <div class="nav-actions">
          <ul class="right" style="position: static; transform: none;">
            <li><a class="nav-link" href="/">Inicio</a></li>
            <li><a class="nav-link" href="/posts">Mis posts</a></li>
          </ul>
          <a href="/posts/new" class="btn nav-new">+ Nuevo</a>
        </div>
      </div>
    </nav>
  </header>

  <main class="page-content">
    <div class="container">
      <% if (error) { %>
        <div class="card-panel red lighten-4 red-text text-darken-4 status-panel">
          <%= error %>
        </div>
      <% } %>

      <div class="card composer-card">
        <div class="card-content">
          <span class="card-title"><%= postToEdit ? "Editar post" : "Nuevo post" %></span>
          <p class="helper-copy">Esta pantalla queda separada del listado para que crear y editar se sientan como vistas distintas.</p>

          <% if (!users.length) { %>
            <p class="red-text text-darken-2">
              No hay usuarios registrados. Primero crea usuarios válidos para poder asignarles posts.
            </p>
          <% } %>

          <form action="<%= postToEdit ? `/posts/${postToEdit._id}/update` : '/posts' %>" method="POST">
            <div class="row">
              <div class="input-field col s12 m6">
                <input id="title" name="title" type="text" minlength="5" maxlength="30" required value="<%= formData.title || '' %>">
                <label for="title" class="<%= formData.title ? 'active' : '' %>">Titulo</label>
              </div>

              <div class="input-field col s12 m6">
                <select id="userId" name="userId" required <%= users.length ? '' : 'disabled' %>>
                  <option value="" disabled <%= !formData.userId ? 'selected' : '' %>>Selecciona un usuario</option>
                  <% users.forEach((user) => { %>
                    <option value="<%= user._id %>" <%= String(formData.userId || '') === String(user._id) ? 'selected' : '' %>>
                      <%= `${user.name} ${user.lastName}` %>
                    </option>
                  <% }) %>
                </select>
                <label for="userId">Autor</label>
              </div>
            </div>

            <div class="row">
              <div class="input-field col s12">
                <textarea id="content" name="content" class="materialize-textarea" minlength="10" required><%= formData.content || '' %></textarea>
                <label for="content" class="<%= formData.content ? 'active' : '' %>">Contenido</label>
              </div>
            </div>

            <div class="row">
              <div class="input-field col s12 m6">
                <input id="hashtags" name="hashtags" type="text" value="<%= formData.hashtags || '' %>">
                <label for="hashtags" class="<%= formData.hashtags ? 'active' : '' %>">Hashtags separados por comas</label>
                <span class="helper-text">Ejemplo: #nodejs, #mongodb, #express</span>
              </div>

              <div class="input-field col s12 m6">
                <input id="imageUrl" name="imageUrl" type="url" value="<%= formData.imageUrl || '' %>">
                <label for="imageUrl" class="<%= formData.imageUrl ? 'active' : '' %>">URL de imagen</label>
              </div>
            </div>

            <div class="form-actions">
              <button class="btn waves-effect waves-light primary-action" type="submit" <%= users.length ? '' : 'disabled' %>>
                <i class="material-icons left"><%= postToEdit ? "save" : "add_circle" %></i>
                <%= postToEdit ? "Actualizar post" : "Crear post" %>
              </button>

              <a href="/posts" class="secondary-action">Cancelar</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const selects = document.querySelectorAll("select");
      M.FormSelect.init(selects);
    });
  </script>
</body>
</html>
